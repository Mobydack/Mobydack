#default {
    fontSize = 18px;
    fontFamily = 'DejavuSans', monospace;
    color1 = #fff;
    color2 = #0f0;
    color3 = #49b9c7;
    .app {
        background-color: #000;
        color: color2;
        font: fontSize fontFamily;
        .separator {
            background-color: color2;
        }
        .list__item {
            padding: 12px 18px;
            .brackets {
                border: 1px solid transparent;
                padding: 0 10px;
                border-image: 1 linear-gradient(90deg, color2 5%, transparent 5%, transparent 95%, color2 95%);  
            }
            &--active {
                background-color: color3;
                color: color1;
                .brackets {
                    border-image: 1 linear-gradient(90deg, color1 5%, transparent 5%, transparent 95%, color1 95%); 
                }
            }
        }
    }
}