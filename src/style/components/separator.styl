.separator-container {
    width: 100%;
    display: flex;
    &.h {
        flex-direction: column;
        .separator {
            width: 100%;
            height: 10px;
        }
    }

    &.v {
        flex-direction: row;
        .separator {
            width: 10px;
        }
    }
    .separator {
        background-color: #333;
    }
}